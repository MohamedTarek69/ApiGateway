{
  "ReverseProxy": {
    "Routes": {
      "identity-route": {
        "ClusterId": "identity-cluster",
        "Match": {
          "Path": "/auth/{**catch-all}"
        },
        "Transforms": [
          { "PathRemovePrefix": "/auth" }
        ]
      },
      "clinic-route": {
        "ClusterId": "clinic-cluster",
        "Match": {
          "Path": "/api/{**catch-all}"
        },
        "Transforms": [
          { "PathRemovePrefix": "/api" }
        ]
      },
      "patiant-route": {
        "ClusterId": "patiant-cluster",
        "Match": {
          "Path": "/patient/{**catch-all}"
        },
        "Transforms": [
          { "PathRemovePrefix": "/patient" }
        ]
      },
      "ai-route": {
        "ClusterId": "ai-cluster",
        "Match": {
          "Path": "/ai/{**catch-all}"
        },
        "Transforms": [
          {
            "PathRemovePrefix": "/ai"
          }
        ]
      }
    },
    "Clusters": {
      "identity-cluster": {
        "Destinations": {
          "destination1": {
            "Address": "http://Clinic-AuthV27:7179/"
          }
        }
      },
      "clinic-cluster": {
        "Destinations": {
          "destination1": {
            "Address": "http://Doctor-ClinicV17:5128/"
          }
        }
      },
      "patiant-cluster": {
        "Destinations": {
          "destination1": {
            "Address": "http://PatientV10:7248/"
          }
        }
      },
      "ai-cluster": {
        "Destinations": {
          "destination1": {
            "Address": "http://Ai-Chatbotv6:7126/"
          }
        }
      }
    }
  },
  "Logging": {
    "LogLevel": {
      "Default": "Information",
      "Microsoft.AspNetCore": "Warning",
      "Yarp.ReverseProxy": "Debug"
    }
  }
}