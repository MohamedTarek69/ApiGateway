{
  "ReverseProxy": {
    "Routes": {
      "identity-route": {
        "ClusterId": "identity-cluster",
        "Match": {
          "Path": "/auth/{**catch-all}"
        },
        "Transforms": [
          { "PathRemovePrefix": "/auth" }
        ]
      },
      "clinic-route": {
        "ClusterId": "clinic-cluster",
        "Match": {
          "Path": "/api/{**catch-all}"
        },
        "Transforms": [
          { "PathRemovePrefix": "/api" }
        ]
      },

      "patiant-route": {
        "ClusterId": "patiant-cluster",
        "Match": {
          "Path": "/patient/{**catch-all}"
        },
        "Transforms": [
          { "PathRemovePrefix": "/patient" }
        ]
      }
    },
    "Clusters": {
      "identity-cluster": {
        "Destinations": {
          "destination1": {
            //"Address": "http://localhost:7179/"
            //"Address": "http://host.docker.internal:8080/"
            "Address": "http://Clinic-AuthV22:7179/"
            //"Address": "http://Clinic-AuthV1000:7179/"
            //"Address": "http://Clinic-Auth-netV14:7179/"
          }
        }
      },
      "clinic-cluster": {
        "Destinations": {
          "destination1": {
            //"Address": "http://localhost:5128/"
            //"Address": "http://host.docker.internal:8081/"
            "Address": "http://Doctor-ClinicV13:5128/"
            //"Address": "http://Doctor-ClinicV1000:5128/"
            //"Address": "http://Doctor-Clinic-netV8:5128/"
          }
        }
      },
      "patiant-cluster": {
        "Destinations": {
          "destination1": {
            //"Address": "http://localhost:7248/"
            "Address": "http://PatientV7:7248/"
          }
        }
      }
    }
  },
  "Logging": {
    "LogLevel": {
      "Default": "Information",
      "Microsoft.AspNetCore": "Warning",
      "Yarp.ReverseProxy": "Debug"
    }
  }
}